{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "plugins": ["@typescript-eslint"],
  "extends": [],
  "rules": {},
  "ignorePatterns": ["node_modules", ".next", "dist", "build", ".git"],
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
      "rules": {}
    }
  ]
}
